# WiFi Manager main app environment example
# Copy values you need into your real environment or a local untracked env file.
# Everything is commented out by default on purpose.
#
# Scope:
# - repo-defined env vars consumed directly by application config
# - common Spring Boot deployment env vars this app typically needs
#
# Notes:
# - `PROJECT_ROOT` is mainly for local development helpers and Docker Compose path resolution.
# - `CAPITVE_PORTAL_IPV6_SUBNET` is intentionally misspelled to match the current key in `application.yml`.

# ------------------------------------------------------------------------------
# Common Spring Boot deployment variables
# ------------------------------------------------------------------------------

# Active Spring profiles, e.g. `dev`.
# SPRING_PROFILES_ACTIVE=dev
# To enable Google OIDC login for the admin UI, include `google` in the active profiles.
# Example: SPRING_PROFILES_ACTIVE=google

# HTTP port for the Spring Boot app.
# SERVER_PORT=8080

# JDBC connection string for the shared application database.
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wifimanager

# Database username.
# SPRING_DATASOURCE_USERNAME=wifimanager

# Database password.
# SPRING_DATASOURCE_PASSWORD=wifimanager

# Hibernate DDL mode. Keep aligned with your deployment strategy.
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Enable Flyway migrations at startup when needed.
# SPRING_FLYWAY_ENABLED=true

# OIDC issuer for admin UI login when you want to override the configured provider.
# Example registration id in dev is `admin`.
# SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/wifimanager

# Google OIDC client id for the `google` Spring profile.
# GOOGLE_OIDC_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OIDC client secret for the `google` Spring profile.
# GOOGLE_OIDC_CLIENT_SECRET=change-me

# Optional Google Workspace customer id used by shared Google Directory API lookups.
# GOOGLE_DIRECTORY_CUSTOMER=my_customer

# Optional override for the Google Directory API base URL.
# GOOGLE_DIRECTORY_API_BASE_URL=https://admin.googleapis.com/admin/directory/v1

# OIDC client id for the admin UI login registration.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_ADMIN_CLIENT_ID=admin-web

# OIDC client secret for the admin UI login registration.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_ADMIN_CLIENT_SECRET=change-me

# Optional explicit OIDC scopes for the admin UI registration.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_ADMIN_SCOPE=openid,profile,email,roles

# ------------------------------------------------------------------------------
# Local development helpers
# ------------------------------------------------------------------------------

# Absolute path to the repo root. Used by dev asset/template resolvers and compose path lookup.
# PROJECT_ROOT=/Users/you/Work/wifi-manager

# ------------------------------------------------------------------------------
# App-specific UI and captive portal settings
# ------------------------------------------------------------------------------

# SSID shown in admin ticket instructions.
# WIFIMANAGER_WIFI_SSID=My WiFi

# Public base URL used for absolute captive portal URLs and the RFC 8908 captive API.
# CAPTIVE_PORTAL_PUBLIC_BASE_URL=https://wifi.example.com

# Force requests from these IPv4 CIDRs to route to `/captive` even for authenticated users.
# Spring expects a list syntax string here.
# CAPTIVE_PORTAL_IPV4_SUBNET=["10.42.0.0/16","192.168.50.0/24"]

# Force requests from these IPv6 CIDRs to route to `/captive`.
# The env name is misspelled in config today; keep that exact spelling until the app config changes.
# CAPITVE_PORTAL_IPV6_SUBNET=["2001:db8:42::/64"]

# ------------------------------------------------------------------------------
# Device fingerprinting
# ------------------------------------------------------------------------------

# Enable or disable fingerprint mismatch evaluation.
# WIFIMANAGER_CAPTIVE_FINGERPRINTING_ENABLED=true

# Score at or above this value triggers audit logging.
# CAPTIVE_FINGERPRINTING_LOG_THRESHOLD=40

# Score at or above this value forces re-authentication.
# CAPTIVE_FINGERPRINTING_ENFORCE_THRESHOLD=70

# Trust a proxy-provided TLS/device fingerprint header.
# CAPTIVE_FINGERPRINTING_TRUSTED_PROXY_ENABLED=true

# Header name used when trusted proxy fingerprint forwarding is enabled.
# CAPTIVE_FINGERPRINTING_TRUSTED_PROXY_HEADER_NAME=X-Device-Tls-Fingerprint

# ------------------------------------------------------------------------------
# Captive auth: Google LDAP / Google Workspace
# ------------------------------------------------------------------------------

# Enable Google LDAP captive authentication.
# GOOGLE_LDAP_CAPTIVE_ENABLED=true

# Google LDAP user search base DN.
# GOOGLE_LDAP_USER_SEARCH_BASE=dc=example,dc=com

# Path to the Google service account JSON used for Google Directory API lookups.
# Used by both Google OIDC admin login enrichment and Google LDAP captive login.
# GOOGLE_LDAP_SERVICE_ACCOUNT_JSON=/run/secrets/google-service-account.json

# Workspace user to impersonate for Google Directory API calls.
# GOOGLE_LDAP_IMPERSONATED_USER=admin@example.com

# Per-group allowed device counts in `GROUP=COUNT;GROUP=COUNT` form.
# GOOGLE_LDAP_ALLOWED_DEVICES_BY_GROUP=WIFI_STAFF=1;WIFI_ADMIN=5

# Optional direct Spring overrides for Google LDAP settings not exposed via placeholders.
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_LDAP_URL=ldaps://ldap.google.com:636
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_USER_SEARCH_FILTER=mail={0}
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_DIRECTORY_CUSTOMER=my_customer
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_DIRECTORY_API_BASE_URL=https://admin.googleapis.com/admin/directory/v1
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_CONNECT_TIMEOUT=5s
# WIFIMANAGER_CAPTIVE_AUTH_GOOGLE_READ_TIMEOUT=5s

# ------------------------------------------------------------------------------
# Captive auth: Keycloak password grant
# ------------------------------------------------------------------------------

# Enable Keycloak captive authentication.
# KEYCLOAK_CAPTIVE_ENABLED=true

# Keycloak realm issuer URI for captive logins.
# KEYCLOAK_CAPTIVE_ISSUER_URI=https://keycloak.example.com/realms/wifimanager

# OAuth client id used by the captive portal.
# KEYCLOAK_CAPTIVE_CLIENT_ID=captive-portal

# OAuth client secret used by the captive portal.
# KEYCLOAK_CAPTIVE_CLIENT_SECRET=change-me

# Per-role allowed device counts in `ROLE=COUNT;ROLE=COUNT` form.
# KEYCLOAK_CAPTIVE_ALLOWED_DEVICES_BY_ROLE=WIFI_STAFF=1;WIFI_ADMIN=5

# ------------------------------------------------------------------------------
# Shared security settings
# ------------------------------------------------------------------------------

# OAuth2 registration id used by UI login pages.
# WIFIMANAGER_SECURITY_OIDC_REGISTRATION_ID=admin

# Registration-to-authorities-provider map.
# Spring map binding via env is awkward; `SPRING_APPLICATION_JSON` is often easier for this one.
# Example:
# SPRING_APPLICATION_JSON={"wifimanager":{"security":{"authorities-provider-by-registration":{"admin":"keycloak-realm-roles"}}}}

# Google OIDC group-to-role mapping in `GROUP=ROLE;GROUP=ROLE` form.
# Only applies to Google UI login and maps Google Directory group identifiers to app roles.
# WIFIMANAGER_SECURITY_GOOGLE_ROLE_BY_GROUP=wifi-admins@example.com=WIFI_ADMIN;wifi-staff@example.com=WIFI_STAFF

# ------------------------------------------------------------------------------
# Captive router-agent integration inside the Spring app
# ------------------------------------------------------------------------------

# Router-agent mode used by the Spring app: `dummy` or `grpc`.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_TYPE=grpc

# gRPC server port exposed by the Spring app for the external routeragent process.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_PORT=9091

# Command timeout for gRPC router-agent operations.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_COMMAND_TIMEOUT=5s

# Enable TLS on the Spring app's router-agent gRPC server.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_ENABLED=true

# Server keystore path for the Spring app gRPC server.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_KEY_STORE_PATH=certs/server.p12

# Server keystore password.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_KEY_STORE_PASSWORD=changeit

# Server keystore type.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_KEY_STORE_TYPE=PKCS12

# Optional separate key password. Defaults to keystore password if omitted.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_KEY_PASSWORD=changeit

# Truststore path used to validate routeragent client certs.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_TRUST_STORE_PATH=certs/truststore.p12

# Truststore password.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_TRUST_STORE_PASSWORD=changeit

# Truststore type.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_TRUST_STORE_TYPE=PKCS12

# Require mutual TLS from the routeragent client.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_REQUIRE_CLIENT_AUTH=true

# ------------------------------------------------------------------------------
# Dummy router-agent mode inside the Spring app
# ------------------------------------------------------------------------------

# Default fallback MAC returned by the in-process dummy router-agent.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_DUMMY_DEFAULT_CLIENT_MAC_ADDRESS=00:00:00:00:00:00

# Default fallback hostname returned by the in-process dummy router-agent.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_DUMMY_DEFAULT_CLIENT_HOSTNAME=dummy-device

# Optional default DHCP vendor class exposed by the dummy router-agent.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_DUMMY_DEFAULT_DHCP_VENDOR_CLASS=android-dhcp-14

# Optional default DHCP parameter request list hash exposed by the dummy router-agent.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_DUMMY_DEFAULT_DHCP_PRL_HASH=hash-a

# Optional default DHCP hostname exposed by the dummy router-agent.
# WIFIMANAGER_CAPTIVE_ROUTER_AGENT_DUMMY_DEFAULT_DHCP_HOSTNAME=e2e-device.local

# Optional explicit IP->MAC overrides for dummy mode.
# Map binding is easiest through `SPRING_APPLICATION_JSON`.
# Example:
# SPRING_APPLICATION_JSON={"wifimanager":{"captive":{"router-agent":{"dummy":{"client-mac-address-by-ip":{"127.0.0.1":"02:00:00:00:00:01"}}}}}}

# Optional explicit IP->hostname overrides for dummy mode.
# Also easiest through `SPRING_APPLICATION_JSON`.
