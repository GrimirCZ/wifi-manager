# WiFi Manager routeragent environment example
# Copy values you need into your real environment or a local untracked env file.
# Everything is commented out by default on purpose.

# ------------------------------------------------------------------------------
# Core connectivity
# ------------------------------------------------------------------------------

# gRPC target for the Spring app router-agent server.
# Required unless observe mode is enabled.
# ROUTERAGENT_GRPC_TARGET=localhost:9091

# Start in observe-only mode.
# When `true`, the agent still watches local network state but skips the gRPC loop and firewall reconciliation.
# ROUTERAGENT_OBSERVE_MODE=false

# Delay before reconnecting to the Spring app gRPC server after disconnects.
# ROUTERAGENT_GRPC_RECONNECT_DELAY=3s

# Timeout for allow/revoke/GetClientInfo actions.
# ROUTERAGENT_ACTION_TIMEOUT=5s

# Periodic full sync interval for pushing authorized state to the firewall backend.
# ROUTERAGENT_SYNC_INTERVAL=5m

# Periodic verification/repair interval for firewall drift reconciliation.
# ROUTERAGENT_RECONCILE_INTERVAL=1m

# ------------------------------------------------------------------------------
# TLS client configuration for routeragent -> Spring app gRPC
# ------------------------------------------------------------------------------

# Enable TLS for the gRPC client connection.
# When enabled, CA file, client cert, and client key are required.
# ROUTERAGENT_TLS_ENABLED=false

# PEM CA bundle used to validate the Spring app server certificate.
# ROUTERAGENT_TLS_CA_FILE=/etc/wifimanager/ca.pem

# PEM client certificate presented to the Spring app.
# ROUTERAGENT_TLS_CERT_FILE=/etc/wifimanager/routeragent.crt

# PEM private key matching the client certificate.
# ROUTERAGENT_TLS_KEY_FILE=/etc/wifimanager/routeragent.key

# Optional SNI / certificate hostname override for TLS verification.
# ROUTERAGENT_TLS_SERVER_NAME=wifi.example.com

# ------------------------------------------------------------------------------
# Firewall backend
# ------------------------------------------------------------------------------

# Use dummy firewall mode instead of nftables.
# Helpful for local testing.
# ROUTERAGENT_DUMMY_MODE=false

# nftables family, usually `inet`.
# ROUTERAGENT_NFT_FAMILY=inet

# nftables table name used for whitelist sets.
# Required unless dummy mode is enabled.
# ROUTERAGENT_NFT_TABLE=wifimanager

# nftables IPv4 set name.
# At least one of v4 or v6 set must be configured unless dummy mode is enabled.
# ROUTERAGENT_NFT_SET_V4=allowed_ipv4

# nftables IPv6 set name.
# ROUTERAGENT_NFT_SET_V6=allowed_ipv6

# ------------------------------------------------------------------------------
# Local network observation
# ------------------------------------------------------------------------------

# Optional whitespace-delimited interface allowlist.
# If set, the Linux netlink observer watches only these interfaces and fails startup if any are missing.
# ROUTERAGENT_MANAGED_INTERFACES=br-lan wlan0 vlan20

# Path to the dnsmasq leases file for realtime hostname ingestion.
# ROUTERAGENT_DNSMASQ_LEASES_PATH=/var/lib/misc/dnsmasq.leases

# ------------------------------------------------------------------------------
# DHCP fingerprint ingestion
# ------------------------------------------------------------------------------

# DHCP fingerprint source:
# - `file` for a dnsmasq log file
# - `journald` for `journalctl -u <unit> -o cat --no-tail -f`
# - empty to disable DHCP fingerprint ingestion
# ROUTERAGENT_DNSMASQ_DHCP_SOURCE=file

# Path to the dnsmasq DHCP log file when `ROUTERAGENT_DNSMASQ_DHCP_SOURCE=file`.
# ROUTERAGENT_DNSMASQ_DHCP_LOG_PATH=/var/log/dnsmasq.log

# systemd unit name when `ROUTERAGENT_DNSMASQ_DHCP_SOURCE=journald`.
# ROUTERAGENT_DNSMASQ_DHCP_JOURNAL_UNIT=dnsmasq.service
