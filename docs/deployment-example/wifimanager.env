SPRING_PROFILES_ACTIVE=google
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/wifimanager
SPRING_DATASOURCE_USERNAME=wifimanager
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_ENABLED=true

WIFIMANAGER_WIFI_SSID=School-Guest
CAPTIVE_PORTAL_PUBLIC_BASE_URL=https://wifi.example.test
CAPTIVE_PORTAL_IPV4_SUBNET=["10.42.30.0/24"]
CAPITVE_PORTAL_IPV6_SUBNET=[]

GOOGLE_OIDC_CLIENT_ID=change-me.apps.googleusercontent.com
GOOGLE_OIDC_CLIENT_SECRET=change-me
GOOGLE_DIRECTORY_CUSTOMER=my_customer

WIFIMANAGER_SECURITY_OIDC_REGISTRATION_ID=admin
WIFIMANAGER_SECURITY_GOOGLE_ROLE_BY_GROUP=wifi-admins@example.test=WIFI_ADMIN;wifi-staff@example.test=WIFI_STAFF

WIFIMANAGER_CAPTIVE_FINGERPRINTING_ENABLED=true
CAPTIVE_FINGERPRINTING_LOG_THRESHOLD=40
CAPTIVE_FINGERPRINTING_ENFORCE_THRESHOLD=70

WIFIMANAGER_CAPTIVE_ROUTER_AGENT_TYPE=grpc
WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_PORT=9091
WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_COMMAND_TIMEOUT=5s
WIFIMANAGER_CAPTIVE_ROUTER_AGENT_GRPC_TLS_ENABLED=false
